# Values are entered as runtime-only Coolify environment variables, never committed.
NODE_ENV=production
ZONGO_IMAGE=ghcr.io/mutabpato/zongo
ZONGO_IMAGE_TAG=sha-REPLACE_WITH_COMMIT
POSTGRES_USER=zongo
POSTGRES_PASSWORD=REPLACE_WITH_URL_ENCODED_SECRET
POSTGRES_DB=zongo
REDIS_PASSWORD=REPLACE_WITH_URL_ENCODED_SECRET
API_HOSTNAME=api.development.example.com
ADMIN_HOSTNAME=admin.development.tailnet.example.com
BREAK_GLASS_SECRET=REPLACE_WITH_SECRET
ADMINJS_COOKIE_SECRET=REPLACE_WITH_SECRET
ADMIN_ALERT_WEBHOOK_URL=
ADMIN_BOOTSTRAP_EMAIL=admin@zongo.app
ADMIN_BOOTSTRAP_TOTP_SECRET=YOUR_UNIQUE_BASE32_TOTP_SECRET