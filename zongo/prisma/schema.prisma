// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum CurrencyCode {
  USD
  CDF
  KES
  UGX
}

enum TransactionStatus {
  INITIATED
  PENDING_COLLECTION
  COLLECTION_SUCCESS
  COLLECTION_FAILED
  PENDING_PAYOUT
  PAYOUT_SUCCESS
  PAYOUT_FAILED
}

enum AuditEventType {
  BUSINESS
  TECHNICAL
}

enum JobType {
  COLLECTION
  PAYOUT
  STATUS_RECHECK
  NOTIFICATION
  RETRY
}

enum JobStatus {
  PENDING
  RUNNING
  SUCCEEDED
  FAILED
}

enum KycTier {
  TIER_0
  TIER_1
  TIER_2
}

enum VerificationStatus {
  PENDING
  SUCCEEDED
  FAILED
}

enum ContactChannel {
  WHATSAPP
  SMS
  EMAIL
  MOBILE_APP
}

model Corridor {
  id String @id @default(cuid())
  code String @unique
  name String
  isActive Boolean @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  policies CorridorPolicy[]
  beneficiaries Beneficiary[]
  transactions TransferTransaction[]
  auditEvents AuditEvent[]

  @@index([isActive, code])
}

model CorridorPolicy {
  id String @id @default(cuid()) 
  corridorId String
  version Int 
  isActive Boolean @default(true)
  sendCurrency CurrencyCode
  payoutCurrency CurrencyCode
  collectionTimeoutMinutes Int @default(15)
  payoutTimeoutMinutes Int @default(15)
  minSendAmountMinor BigInt?
  maxSendAmountMinor BigInt?
  rules Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  corridor Corridor @relation(fields: [corridorId], references: [id], onDelete: Restrict)

  @@unique([corridorId, version])
  @@index([corridorId, isActive])
}

model Beneficiary {
  id String @id @default(cuid())
  familyId String @default(cuid())
  corridorId String
  userId String
  displayName String
  payoutCountryCode String
  payoutCurrency CurrencyCode
  phoneNumber String
  payoutAccount Json?
  version Int @default(1)
  supersedesId String?
  isCurrent Boolean @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  corridor Corridor @relation(fields: [corridorId], references: [id], onDelete: Restrict)
  transactions TransferTransaction[] @relation("BeneficiaryTransactions")
  retryTransactions TransferTransaction[] @relation("RetryBeneficiaryTransactions")
  supersedes Beneficiary? @relation("BeneficiaryVersions", fields: [supersedesId], references: [id], onDelete: Restrict)
  revisions Beneficiary[] @relation("BeneficiaryVersions")

  @@index([userId, corridorId])
  @@index([corridorId, phoneNumber])
  @@index([userId, corridorId, isCurrent])
  @@unique([familyId, version])
}

model TransferTransaction {
  id String @id @default(cuid())
  reference String @unique
  corridorId String
  senderUserId String
  beneficiaryId String?
  retryBeneficiaryId String?
  status TransactionStatus @default(INITIATED)
  region String?
  partitionKey String?
  sendAmountMinor BigInt
  sendCurrency CurrencyCode
  payoutAmountMinor BigInt?
  payoutCurrency CurrencyCode?
  partnerReference String?
  idempotencyKey String @unique
  activeJobKey String?
  collectionRequestAt DateTime?
  collectionCompletedAt DateTime?
  payoutRequestedAt DateTime?
  payoutCompletedAt DateTime?
  failedReason String?
  metadata Json?
  archivedAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  corridor Corridor @relation(fields: [corridorId], references: [id], onDelete: Restrict)
  beneficiary Beneficiary? @relation("BeneficiaryTransactions", fields: [beneficiaryId], references: [id], onDelete: SetNull)
  retryBeneficiary Beneficiary? @relation("RetryBeneficiaryTransactions", fields: [retryBeneficiaryId], references: [id], onDelete: SetNull)
  auditEvents AuditEvent[]
  workerJobs WorkerJob[]

  @@index([corridorId, createdAt])
  @@index([senderUserId, status])
  @@index([status, updatedAt])
}

model AuditEvent {
  id String @id @default(cuid())
  eventType AuditEventType
  name String
  actorType String?
  actorId String?
  corridorId String?
  transactionId String?
  payload Json
  createdAt DateTime @default(now())

  corridor Corridor? @relation(fields: [corridorId], references: [id], onDelete: SetNull)
  transaction TransferTransaction? @relation(fields: [transactionId], references: [id], onDelete: SetNull)

  @@index([transactionId, createdAt])
  @@index([corridorId, createdAt])
  @@index([eventType, createdAt])
}

model WorkerJob {
  id String @id @default(cuid())
  dedupKey String @unique
  jobType JobType
  transactionReference String
  transactionId String?
  status JobStatus @default(PENDING)
  payload Json
  attempts Int @default(0)
  lockedAt DateTime?
  leaseExpiresAt DateTime?
  processedAt DateTime?
  lastError String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  transaction TransferTransaction? @relation(fields: [transactionId], references: [id], onDelete: SetNull)

  @@index([transactionReference, jobType])
  @@index([status, createdAt])
  @@index([status, leaseExpiresAt])
}

model ProcessedJob {
  id String @id @default(cuid())
  transactionReference String
  jobType String
  processedAt DateTime @default(now())

  @@unique([transactionReference, jobType])
}

/// Durable, channel-agnostic sender identity. Email remains optional for WhatsApp onboarding.
model SenderProfile {
  id String @id @default(cuid())
  userId String @unique
  legalName String?
  email String? @unique
  senderPhoneNumber String? @unique
  whatsappPhoneNumber String
  backupPhoneNumber String?
  tier KycTier @default(TIER_0)
  verifiedAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  verificationHistory SenderVerification[]
  phoneReplacementHistory SenderPhoneReplacement[]
  contactPreferences ContactPreference?
  channelMigrations ChannelMigration[]
  tierLimitOverride SenderTierLimitOverride?

  @@index([senderPhoneNumber])
  @@index([tier, createdAt])
}

/// Smile ID outcomes are immutable facts; the latest successful one may promote the profile.
model SenderVerification {
  id String @id @default(cuid())
  senderProfileId String
  provider String @default("SMILE_ID")
  providerReference String @unique
  status VerificationStatus
  verifiedPhoneNumber String?
  failureReason String?
  completedAt DateTime?
  createdAt DateTime @default(now())

  senderProfile SenderProfile @relation(fields: [senderProfileId], references: [id], onDelete: Restrict)

  @@index([senderProfileId, createdAt])
  @@index([status, createdAt])
}

model SenderPhoneReplacement {
  id String @id @default(cuid())
  senderProfileId String
  previousPhoneNumber String
  replacementPhoneNumber String
  verificationId String @unique
  replacedAt DateTime @default(now())

  senderProfile SenderProfile @relation(fields: [senderProfileId], references: [id], onDelete: Restrict)

  @@index([senderProfileId, replacedAt])
}

/// Global defaults are intentionally simple rows, suitable for an AdminJS resource.
model TierLimitPolicy {
  id String @id @default(cuid())
  tier KycTier @unique
  perTransferLimitMinor BigInt
  dailyLimitMinor BigInt
  updatedByAdminId String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/// Rare support/admin exception for a single sender; null means use global policy.
model SenderTierLimitOverride {
  id String @id @default(cuid())
  senderProfileId String @unique
  perTransferLimitMinor BigInt?
  dailyLimitMinor BigInt?
  reason String
  updatedByAdminId String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  senderProfile SenderProfile @relation(fields: [senderProfileId], references: [id], onDelete: Restrict)
}

model ContactPreference {
  id String @id @default(cuid())
  senderProfileId String @unique
  preferredChannel ContactChannel @default(WHATSAPP)
  preferredLanguage String @default("en")
  notificationsOptedIn Boolean @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  senderProfile SenderProfile @relation(fields: [senderProfileId], references: [id], onDelete: Restrict)
}

/// Explicit record of a profile's migration to a future channel without changing identity shape.
model ChannelMigration {
  id String @id @default(cuid())
  senderProfileId String
  fromChannel ContactChannel @default(WHATSAPP)
  toChannel ContactChannel
  status String @default("PENDING")
  externalReference String?
  migratedAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  senderProfile SenderProfile @relation(fields: [senderProfileId], references: [id], onDelete: Restrict)

  @@index([senderProfileId, createdAt])
}
