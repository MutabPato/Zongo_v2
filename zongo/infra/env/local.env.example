# Copy to .env.local. The local Admin container loads this file and seeds this
# identity every time that container starts.
NODE_ENV=development
DATABASE_URL=postgresql://zongo:zongo-local-only@localhost:15432/zongo?schema=public
LOCAL_ADMIN_EMAIL=admin@zongo.app
# Generate a unique Base32 TOTP secret, add it to your authenticator app, then set it here.
LOCAL_ADMIN_TOTP_SECRET=
